# ══════════════════════════════════════════════════════════════════════════
# AutoPatch — Configuration
# ══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#
# Supports both self-hosted SonarQube and SonarCloud.

# ── SonarQube / SonarCloud ──────────────────────────────────────────────
# For SonarCloud:
#   SONAR_HOST_URL=https://sonarcloud.io
#   SONAR_ORGANIZATION=your-org-key   (required for SonarCloud)
#
# For self-hosted SonarQube:
#   SONAR_HOST_URL=http://localhost:9000
#   SONAR_ORGANIZATION=               (leave empty)

SONAR_HOST_URL=https://sonarcloud.io
SONAR_TOKEN=<YOUR_SONAR_TOKEN>
SONAR_PROJECT_KEY=<YOUR_PROJECT_KEY>
SONAR_ORGANIZATION=<YOUR_SONARCLOUD_ORG_KEY>

# Path to the source code being analysed
PROJECT_PATH=<ABSOLUTE_PATH_TO_YOUR_SOURCE_CODE>

# Backup directory (relative to PROJECT_PATH)
BACKUP_DIR=.sonar-backups

# ── LLM Providers ───────────────────────────────────────────────────────
# At least ONE API key is required.
# Each provider auto-cycles through all its model variants.
#
# Fallback order:
#   Groq (6 models) → Gemini (6 models) → OpenAI (7 models)
#   = 19 total model variants

# Groq — 6 models: llama-3.3-70b, llama-3.1-8b, gpt-oss-120b, gpt-oss-20b, qwen-qwq-32b, deepseek-r1-70b
GROQ_API_KEY=<YOUR_GROQ_API_KEY>

# Gemini — 6 models: 2.5-flash, 2.5-pro, 2.0-flash, 2.0-flash-lite, 3-flash, 3.1-flash-lite
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>

# OpenAI — 7 models: gpt-4o-mini, gpt-4o, gpt-4.1-mini, gpt-4.1-nano, gpt-4.1, o4-mini, o3-mini
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# ── GitHub Integration ──────────────────────────────────────────────────
# Required for creating Pull Requests after fixing code
# Generate at: https://github.com/settings/tokens (needs 'repo' scope)
GITHUB_TOKEN=<YOUR_GITHUB_PAT>
